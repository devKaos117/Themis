transcript() { script -q -a "$(date +%FT%H:%M:%S)${1:+ $1}.script"; }

# ====== Data encoding
enCode() { if [ -n "$1" ]; then printf '%s' "$1"; else cat /dev/stdin ; fi | od -An -tx1 | tr -d ' \n' | base64; }
deCode() { if [ -n "$1" ]; then printf '%s' "$1"; else cat /dev/stdin ; fi | base64 -d | sed 's/../\\x&/g' | xargs -0 printf "%b"; }
pwsh64() { if [ -n "$1" ]; then printf '%s' "$1"; else cat /dev/stdin ; fi | iconv -t UTF-16LE | base64 -w 0 }

