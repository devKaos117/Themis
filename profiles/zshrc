#====== Port range batching
port_batch() {
	# ====== Initializations
	declare -r TOTAL_PORTS=65536
	declare -r MAX_PORT=65535

	declare -r RED="\033[1;91m"
	declare -r BLUE="\033[1;94m"
	declare -r RESET="\033[0m"

	TOTAL_BATCHES="$1"
	BATCH_INDEX="$2"

	# ====== Validation
	if [[ "$#" -ne 2 ]]; then
		echo "${BLUE}Usage:${RESET} $0 [NUMBER(batches)] [NUMBER(index)]"
		echo "${BLUE}Description:${RESET} Divide the port range (0-65535) into NUMBER(batches) and return the range for the specified NUMBER(index)"
		return 1
	fi

	# Ensure inputs are positive integers using regular expressions
	if ! [[ "$TOTAL_BATCHES" =~ ^[0-9]+$ ]] || ! [[ "$BATCH_INDEX" =~ ^[0-9]+$ ]]; then
		echo "${RED}Error:${RESET} Both arguments must be positive integers" >&2
		return 1
	fi

	if (( TOTAL_BATCHES < 1 )); then
		echo "${RED}Error:${RESET} Total batches must be at least 1" >&2
		return 1
	fi

	if (( BATCH_INDEX < 1 || BATCH_INDEX > TOTAL_BATCHES )); then
		echo "${RED}Error:${RESET} Batch index must be between 1 and ${TOTAL_BATCHES}" >&2
		return 1
	fi

	# ====== Calculation
	# Calculate base size of each batch and any leftover ports
	BATCH_SIZE=$(( TOTAL_PORTS / TOTAL_BATCHES ))
	REMAINDER=$(( TOTAL_PORTS % TOTAL_BATCHES ))

	# Calculate start and end ports (0-indexed math translated to standard port numbers)
	START_PORT=$(( (BATCH_INDEX - 1) * BATCH_SIZE ))
	END_PORT=$(( START_PORT + BATCH_SIZE - 1 ))

	# Distribute the remainder to the very last batch so no ports are missed
	if (( BATCH_INDEX == TOTAL_BATCHES )); then
		END_PORT=$(( END_PORT + REMAINDER ))
	fi

	# Safety cap (just in case)
	if (( END_PORT > MAX_PORT )); then
		END_PORT=$MAX_PORT
	fi

	# ====== Output
	echo "${START_PORT}-${END_PORT}"
}

# ====== Data encoding
enCode() { printf '%s' "$1" | od -An -tx1 | tr -d ' \n' | base64; }
deCode() { printf '%s' "$1" | base64 -d | sed 's/../\\x&/g' | xargs -0 printf "%b"; }
win_pw64() { echo -n "$1" | iconv -t UTF-16LE | base64 -w 0 }

